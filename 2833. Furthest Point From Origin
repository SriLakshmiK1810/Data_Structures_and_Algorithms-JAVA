class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int left=0,right=0,b=0;
        for(char c:moves.toCharArray()){
            if(c=='L') left++;
            else if(c=='R' ) right++;
            else b++;
        }
        return Math.abs(left-right)+b;
        
    }
}
